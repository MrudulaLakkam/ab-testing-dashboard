{
  "compilerOptions": {
    "target": "ES2015",
    "module": "umd",
    "lib": ["ES2015", "DOM"],
    "declaration": true,
    "outDir": "dist",
    "strict": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "moduleResolution": "node"
  },
  "include": ["src"],
  "exclude": ["node_modules"]
}
